---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import VerticalImageCard from "../components/VerticalImageCard.astro";
---

<BaseLayout
  title="Accompagnements en sophrologie à Loudéac – Alexandra Coirier"
  description="Séances à l’unité, Parcours Envol et Parcours Harmonie : accompagnement en sophrologie pour apaiser l’anxiété, le stress, la surcharge mentale et retrouver son équilibre à Loudéac."
>
  <Header />

  <main>
    <section class="mx-auto max-w-7xl px-4 sm:px-6 py-10 md:py-16">
      <!-- INTRO -->
      <section class="grid lg:grid-cols-[0.75fr_1.25fr] gap-8 items-stretch">
        <VerticalImageCard
          src="/images/sophro/respiration-et-centration.webp"
          alt="Respiration et centration pendant un accompagnement en sophrologie"
          ratio="10 / 15"
          objectPosition="center 35%"
          animation="slide-right"
          className="h-full"
          mobileStart="0%"
          mobileMiddle="30%"
          mobileEnd="65%"
          mobileDuration="16s"
        />

        <div class="soft-card rounded-[1.5rem] md:rounded-[2.5rem] p-5 md:p-10 slide-left flex flex-col justify-center">
          <p class="text-sm uppercase tracking-[0.25em] text-[var(--brown-soft)]">
            Accompagnements
          </p>

          <h1 class="mt-4 text-4xl md:text-5xl font-semibold text-[var(--brown-deep)]">
            Les différentes façons d’être accompagné
          </h1>

          <p class="mt-5 text-lg leading-relaxed text-[var(--text)]">
            Je propose deux formes d’<strong class="font-semibold text-[var(--brown-deep)]">accompagnement en sophrologie</strong> :
            des <strong class="font-semibold text-[var(--brown-deep)]">séances à l’unité</strong>,
            pour un besoin ponctuel ou un premier contact, et des
            <strong class="font-semibold text-[var(--brown-deep)]">parcours d’accompagnement</strong>,
            pour installer des changements plus profonds et durables.
          </p>

          <p class="mt-4 text-lg leading-relaxed text-[var(--text)]">
            Chaque accompagnement est personnalisé et s’adapte à votre rythme,
            à votre situation et à vos besoins.
          </p>
        </div>
      </section>

      <section class="mt-8 section-bg-new rounded-[2.5rem] p-8 md:p-10">
        <!-- SEANCES -->
        <section class="soft-card rounded-[2rem] p-8 fade-in">
          <h2 class="text-2xl font-semibold text-[var(--brown-deep)]">
            Séances à l’unité
          </h2>

          <p class="mt-5 leading-relaxed text-[var(--text)]">
            Les <strong class="font-semibold text-[var(--brown-deep)]">séances à l’unité</strong>
            conviennent si vous souhaitez un soutien ponctuel,
            <strong class="font-semibold text-[var(--brown-deep)]">découvrir la sophrologie</strong>
            ou avancer à votre rythme sans engagement sur un parcours.
          </p>

          <div class="mt-8 grid md:grid-cols-2 gap-6">
            <div class="rounded-[1.5rem] bg-white/70 p-6 zoom-in">
              <h3 class="text-xl font-semibold text-[var(--brown-deep)]">
                Séance individuelle
              </h3>
              <p class="mt-3 text-[var(--text)]">Adulte ou enfant</p>
              <p class="mt-5 text-4xl font-semibold text-[var(--brown-deep)]">
                60 €
              </p>
            </div>

            <div class="rounded-[1.5rem] bg-white/70 p-6 zoom-in">
              <h3 class="text-xl font-semibold text-[var(--brown-deep)]">
                Séance duo parent-enfant
              </h3>
              <p class="mt-3 text-[var(--text)]">
                Un espace partagé pour avancer ensemble.
              </p>
              <p class="mt-5 text-4xl font-semibold text-[var(--brown-deep)]">
                70 €
              </p>
            </div>
          </div>

          <p class="mt-6 italic text-[var(--brown-soft)]">
            Ces séances peuvent aussi être un premier pas avant d’envisager un parcours plus structuré.
          </p>
        </section>

        <!-- POURQUOI -->
        <section class="mt-8 soft-card rounded-[2rem] p-8 slide-left">
          <h2 class="text-2xl font-semibold text-[var(--brown-deep)]">
            Pourquoi choisir un parcours ?
          </h2>

          <div class="mt-5 space-y-4 leading-relaxed text-[var(--text)]">
            <p>
              Certaines situations demandent plus qu’une séance ponctuelle.
              Lorsqu’on traverse une période de
              <strong class="font-semibold text-[var(--brown-deep)]">fatigue</strong>,
              d’<strong class="font-semibold text-[var(--brown-deep)]">anxiété</strong>
              ou de transition, le corps et l’esprit ont souvent besoin de temps
              pour <strong class="font-semibold text-[var(--brown-deep)]">retrouver leur équilibre</strong>.
            </p>

            <p>
              Les <strong class="font-semibold text-[var(--brown-deep)]">parcours d’accompagnement</strong>
              offrent un cadre progressif et sécurisant.
              D’une séance à l’autre, vous apprenez à mieux comprendre votre fonctionnement,
              à <strong class="font-semibold text-[var(--brown-deep)]">relâcher les tensions</strong>
              et à renforcer vos
              <strong class="font-semibold text-[var(--brown-deep)]">ressources intérieures</strong>.
            </p>

            <p>
              Les pratiques proposées entre les séances permettent d’ancrer ces changements
              dans votre quotidien. Le parcours devient alors un véritable
              <strong class="font-semibold text-[var(--brown-deep)]">chemin d’évolution</strong>,
              qui soutient votre autonomie et votre capacité à retrouver un
              <strong class="font-semibold text-[var(--brown-deep)]">équilibre durable</strong>.
            </p>
          </div>
        </section>

        <!-- PARCOURS -->
        <section class="mt-8 grid md:grid-cols-2 gap-6">
          <div class="soft-card rounded-[2rem] p-8 slide-right">
            <p class="text-sm uppercase tracking-[0.25em] text-[var(--brown-soft)]">
              Parcours Envol
            </p>

            <h2 class="mt-4 text-2xl font-semibold text-[var(--brown-deep)]">
              Découverte et transformation
            </h2>

            <p class="mt-5 leading-relaxed text-[var(--text)]">
              Ce parcours est souvent le point de départ de l’accompagnement.
              Il aide à <strong class="font-semibold text-[var(--brown-deep)]">apaiser l’anxiété</strong>,
              se libérer de ce qui pèse,
              <strong class="font-semibold text-[var(--brown-deep)]">se reconnecter à soi</strong>
              et amorcer un
              <strong class="font-semibold text-[var(--brown-deep)]">changement durable</strong>.
            </p>

            <ul class="mt-5 space-y-3 leading-relaxed text-[var(--text)]">
              <li>• 6 séances personnalisées, individuelles ou parent-enfant selon les besoins</li>
              <li>• Solo : 360 €</li>
              <li>• Duo parent-enfant : 420 €</li>
              <li>• Paiement possible en 1 ou 2 fois</li>
            </ul>
          </div>

          <div class="soft-card rounded-[2rem] p-8 slide-left">
            <p class="text-sm uppercase tracking-[0.25em] text-[var(--brown-soft)]">
              Parcours Harmonie
            </p>

            <h2 class="mt-4 text-2xl font-semibold text-[var(--brown-deep)]">
              Stabilisation et ancrage
            </h2>

            <p class="mt-5 leading-relaxed text-[var(--text)]">
              Ce parcours s’adresse aux personnes ayant déjà réalisé le
              <strong class="font-semibold text-[var(--brown-deep)]">Parcours Envol</strong>
              et souhaitant consolider les changements amorcés,
              <strong class="font-semibold text-[var(--brown-deep)]">stabiliser leur équilibre</strong>
              ou approfondir leur cheminement.
            </p>

            <ul class="mt-5 space-y-3 leading-relaxed text-[var(--text)]">
              <li>• 4 à 5 séances personnalisées</li>
              <li>• Solo : 240 € à 300 €</li>
              <li>• Duo parent-enfant : 280 € à 350 €</li>
              <li>• Paiement possible en 1 ou 2 fois</li>
            </ul>
          </div>
        </section>

        <!-- ENVOL DETAIL -->
        <section class="mt-8 grid lg:grid-cols-[1.15fr_0.85fr] gap-8 items-stretch">
          <div class="soft-card rounded-[2rem] p-8 fade-in flex flex-col justify-center">
            <p class="text-sm uppercase tracking-[0.25em] text-[var(--brown-soft)]">
              Parcours Envol
            </p>

            <h2 class="mt-4 text-2xl font-semibold text-[var(--brown-deep)]">
              Se reconnecter à soi et retrouver son équilibre
            </h2>

            <div class="mt-5 space-y-4 leading-relaxed text-[var(--text)]">
              <p>
                Le <strong class="font-semibold text-[var(--brown-deep)]">Parcours Envol</strong>
                est un <strong class="font-semibold text-[var(--brown-deep)]">accompagnement en sophrologie</strong>
                conçu pour les personnes qui traversent une période de
                <strong class="font-semibold text-[var(--brown-deep)]">fatigue</strong>,
                d’<strong class="font-semibold text-[var(--brown-deep)]">anxiété</strong>,
                de <strong class="font-semibold text-[var(--brown-deep)]">surcharge mentale</strong>
                ou de transition dans leur vie.
              </p>

              <p>
                Lorsque tout devient trop lourd ou confus, il peut être difficile de savoir
                par où commencer. Ce parcours offre un espace pour ralentir,
                <strong class="font-semibold text-[var(--brown-deep)]"> déposer ce qui pèse</strong>
                et retrouver progressivement plus de
                <strong class="font-semibold text-[var(--brown-deep)]"> clarté</strong>
                et de <strong class="font-semibold text-[var(--brown-deep)]">stabilité intérieure</strong>.
              </p>

              <p>
                Au fil des séances, vous apprenez à
                <strong class="font-semibold text-[var(--brown-deep)]">relâcher les tensions</strong>,
                à mieux comprendre vos
                <strong class="font-semibold text-[var(--brown-deep)]"> émotions</strong>
                et à vous
                <strong class="font-semibold text-[var(--brown-deep)]"> reconnecter à vos ressources</strong>.
                Pas à pas, votre corps et votre esprit retrouvent un rythme plus apaisé
                et un nouvel élan peut émerger.
              </p>

              <p>
                Le Parcours Envol est une invitation à prendre soin de vous,
                à votre rythme, dans un cadre soutenant et bienveillant.
              </p>
            </div>
          </div>

          <VerticalImageCard
            src="/images/sophro/moi-au-milieu-des-cerisiers.webp"
            alt="Se reconnecter à soi et retrouver son équilibre avec la sophrologie"
            ratio="4 / 5"
            objectPosition="center 35%"
            animation="slide-left"
            className="h-full"
            mobileStart="0%"
            mobileMiddle="35%"
            mobileEnd="70%"
          />
        </section>

        <!-- CE QUE COMPREND -->
        <section class="mt-8 soft-card rounded-[2rem] p-8 md:p-10 fade-in">
          <div class="max-w-4xl">
            <h2 class="text-2xl font-semibold text-[var(--brown-deep)]">
              Ce que comprend le Parcours Envol
            </h2>

            <p class="mt-5 leading-relaxed text-[var(--text)]">
              Au-delà des séances, le parcours propose un cadre soutenant
              qui favorise <strong class="font-semibold text-[var(--brown-deep)]">l’intégration</strong>
              et <strong class="font-semibold text-[var(--brown-deep)]">l’autonomie</strong>.
            </p>
          </div>

          <div class="mt-10 grid md:grid-cols-2 xl:grid-cols-3 gap-6">
            <div class="rounded-[1.75rem] bg-white/75 p-7 zoom-in min-h-[180px] flex flex-col justify-start">
              <div class="text-4xl">🧭</div>
              <h3 class="mt-4 text-xl font-semibold text-[var(--brown-deep)]">
                Suivi personnalisé
              </h3>
              <p class="mt-3 leading-relaxed text-[var(--text)]">
                Nous clarifions ensemble votre situation et la direction
                vers laquelle vous souhaitez évoluer.
              </p>
            </div>

            <div class="rounded-[1.75rem] bg-white/75 p-7 zoom-in min-h-[180px] flex flex-col justify-start">
              <div class="text-4xl">🎧</div>
              <h3 class="mt-4 text-xl font-semibold text-[var(--brown-deep)]">
                Audios personnalisés
              </h3>
              <p class="mt-3 leading-relaxed text-[var(--text)]">
                Vous recevez des pratiques audio pour favoriser
                <strong class="font-semibold text-[var(--brown-deep)]"> l’apaisement</strong>,
                relâcher les tensions et soutenir votre progression.
              </p>
            </div>

            <div class="rounded-[1.75rem] bg-white/75 p-7 zoom-in min-h-[180px] flex flex-col justify-start">
              <div class="text-4xl">🌿</div>
              <h3 class="mt-4 text-xl font-semibold text-[var(--brown-deep)]">
                Exercices
              </h3>
              <p class="mt-3 leading-relaxed text-[var(--text)]">
                Des pratiques simples entre les séances :
                <strong class="font-semibold text-[var(--brown-deep)]"> respiration</strong>,
                pauses conscientes, rituels d’ancrage.
              </p>
            </div>

            <div class="rounded-[1.75rem] bg-white/75 p-7 zoom-in min-h-[180px] flex flex-col justify-start">
              <div class="text-4xl">💬</div>
              <h3 class="mt-4 text-xl font-semibold text-[var(--brown-deep)]">
                Accompagnement
              </h3>
              <p class="mt-3 leading-relaxed text-[var(--text)]">
                Un lien de continuité avec la possibilité d’échanger par message
                et de recevoir des soutiens ponctuels.
              </p>
            </div>

            <div class="rounded-[1.75rem] bg-white/75 p-7 zoom-in min-h-[180px] flex flex-col justify-start md:col-span-2 xl:col-span-2">
              <div class="text-4xl">✨</div>
              <h3 class="mt-4 text-xl font-semibold text-[var(--brown-deep)]">
                Intégration
              </h3>
              <p class="mt-3 leading-relaxed text-[var(--text)]">
                La dernière séance permet de consolider les ressources installées.
                Un temps de retour est également proposé pour observer les évolutions
                et soutenir votre autonomie.
              </p>
            </div>
          </div>
        </section>

        <!-- FINAL -->
        <section class="mt-8 parcours-check-section">
          <div class="parcours-check-card">
            <div class="mx-auto max-w-4xl">
              <h2 class="parcours-check-title">
                Ce parcours est fait pour vous si...
              </h2>

              <ul class="parcours-check-list">
                <li class="parcours-check-item">
                  <span class="parcours-check-box">✓</span>
                  <span class="parcours-check-text">
                    Vous traversez une période de <strong>fatigue</strong>, de <strong>surcharge mentale</strong> ou d’<strong>anxiété</strong>.
                  </span>
                </li>

                <li class="parcours-check-item">
                  <span class="parcours-check-box">✓</span>
                  <span class="parcours-check-text">
                    Vous ressentez le besoin de ralentir et de prendre soin de vous.
                  </span>
                </li>

                <li class="parcours-check-item">
                  <span class="parcours-check-box">✓</span>
                  <span class="parcours-check-text">
                    Vous souhaitez retrouver plus de <strong>clarté</strong>, de <strong>stabilité</strong> et d’élan dans votre vie.
                  </span>
                </li>

                <li class="parcours-check-item">
                  <span class="parcours-check-box">✓</span>
                  <span class="parcours-check-text">
                    Vous avez envie d’apprendre des <strong>outils concrets</strong> pour gérer vos émotions et relâcher les tensions.
                  </span>
                </li>

                <li class="parcours-check-item">
                  <span class="parcours-check-box">✓</span>
                  <span class="parcours-check-text">
                    Vous souhaitez un accompagnement structuré, progressif et bienveillant, qui s’adapte à votre rythme.
                  </span>
                </li>
              </ul>

              <div class="parcours-check-buttons">
                <a
                  href="/contact"
                  class="parcours-check-btn parcours-check-btn-primary"
                >
                  Prendre rendez-vous
                </a>

                <a
                  href="/tarifs"
                  class="parcours-check-btn parcours-check-btn-secondary"
                >
                  Voir les tarifs
                </a>
              </div>
            </div>
          </div>
        </section>

        <style>
          .parcours-check-section {
            opacity: 0;
            transform: translateY(34px);
            transition:
              opacity 1.1s cubic-bezier(0.22, 1, 0.36, 1),
              transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
          }

          .parcours-check-section.is-visible {
            opacity: 1;
            transform: translateY(0);
          }

          .parcours-check-card {
            border-radius: 2.5rem;
            background:
              radial-gradient(circle at top left, rgba(170, 183, 161, 0.16), transparent 34%),
              radial-gradient(circle at bottom right, rgba(111, 136, 146, 0.10), transparent 38%),
              linear-gradient(135deg, #f8f3ec, #fffaf4);
            padding: 2.2rem;
            box-shadow: 0 18px 46px rgba(79, 64, 58, 0.08);
          }

          .parcours-check-title {
            font-size: clamp(1.7rem, 3vw, 2.35rem);
            font-weight: 600;
            color: var(--brown-deep);
          }

          .parcours-check-list {
            margin-top: 2.5rem;
            display: grid;
            gap: 1.55rem;
            color: var(--text);
          }

          .parcours-check-item {
            display: flex;
            align-items: flex-start;
            gap: 1.1rem;
            opacity: 0;
            transform: translateY(24px);
          }

          .parcours-check-box {
            margin-top: 0.15rem;
            width: 2rem;
            height: 2rem;
            flex: 0 0 2rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 0.75rem;
            background: white;
            color: transparent;
            border: 1px solid rgba(111, 136, 146, 0.25);
            box-shadow: 0 8px 20px rgba(79, 64, 58, 0.06);
            transform: scale(0.92);
          }

          .parcours-check-text {
            font-size: clamp(1.08rem, 1.6vw, 1.28rem);
            line-height: 1.7;
            transform-origin: left center;
          }

          .parcours-check-text strong {
            font-weight: 700;
            color: var(--brown-deep);
          }

          .parcours-check-section.is-visible .parcours-check-item {
            animation: checkItemAppear 1.05s cubic-bezier(0.22, 1, 0.36, 1) forwards;
          }

          .parcours-check-section.is-visible .parcours-check-item:nth-child(1) {
            animation-delay: 0.35s;
          }

          .parcours-check-section.is-visible .parcours-check-item:nth-child(2) {
            animation-delay: 1.35s;
          }

          .parcours-check-section.is-visible .parcours-check-item:nth-child(3) {
            animation-delay: 2.35s;
          }

          .parcours-check-section.is-visible .parcours-check-item:nth-child(4) {
            animation-delay: 3.35s;
          }

          .parcours-check-section.is-visible .parcours-check-item:nth-child(5) {
            animation-delay: 4.35s;
          }

          .parcours-check-section.is-visible .parcours-check-box {
            animation: checkBoxValidate 0.95s cubic-bezier(0.22, 1, 0.36, 1) forwards;
          }

          .parcours-check-section.is-visible .parcours-check-item:nth-child(1) .parcours-check-box {
            animation-delay: 0.75s;
          }

          .parcours-check-section.is-visible .parcours-check-item:nth-child(2) .parcours-check-box {
            animation-delay: 1.75s;
          }

          .parcours-check-section.is-visible .parcours-check-item:nth-child(3) .parcours-check-box {
            animation-delay: 2.75s;
          }

          .parcours-check-section.is-visible .parcours-check-item:nth-child(4) .parcours-check-box {
            animation-delay: 3.75s;
          }

          .parcours-check-section.is-visible .parcours-check-item:nth-child(5) .parcours-check-box {
            animation-delay: 4.75s;
          }

          .parcours-check-section.is-visible .parcours-check-text {
            animation: textGrow 0.95s cubic-bezier(0.22, 1, 0.36, 1) forwards;
          }

          .parcours-check-section.is-visible .parcours-check-item:nth-child(1) .parcours-check-text {
            animation-delay: 0.85s;
          }

          .parcours-check-section.is-visible .parcours-check-item:nth-child(2) .parcours-check-text {
            animation-delay: 1.85s;
          }

          .parcours-check-section.is-visible .parcours-check-item:nth-child(3) .parcours-check-text {
            animation-delay: 2.85s;
          }

          .parcours-check-section.is-visible .parcours-check-item:nth-child(4) .parcours-check-text {
            animation-delay: 3.85s;
          }

          .parcours-check-section.is-visible .parcours-check-item:nth-child(5) .parcours-check-text {
            animation-delay: 4.85s;
          }

          .parcours-check-buttons {
            margin-top: 3rem;
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
          }

          .parcours-check-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 9999px;
            padding: 0.95rem 1.8rem;
            font-weight: 600;
            opacity: 0;
            transform: scale(0.92);
            transition:
              background 0.35s ease,
              transform 0.35s ease,
              box-shadow 0.35s ease;
          }

          .parcours-check-btn:hover {
            transform: translateY(-2px) scale(1.03);
            box-shadow: 0 12px 26px rgba(79, 64, 58, 0.12);
          }

          .parcours-check-btn-primary {
            background: var(--brown-soft);
            color: white;
          }

          .parcours-check-btn-primary:hover {
            background: var(--brown-deep);
          }

          .parcours-check-btn-secondary {
            background: rgba(255, 255, 255, 0.82);
            color: var(--brown-deep);
            border: 1px solid rgba(111, 136, 146, 0.18);
          }

          .parcours-check-btn-secondary:hover {
            background: white;
          }

          .parcours-check-section.is-visible .parcours-check-btn:nth-child(1) {
            animation: buttonPop 1.15s cubic-bezier(0.22, 1, 0.36, 1) forwards;
            animation-delay: 5.9s;
          }

          .parcours-check-section.is-visible .parcours-check-btn:nth-child(2) {
            animation: buttonPop 1.15s cubic-bezier(0.22, 1, 0.36, 1) forwards;
            animation-delay: 6.7s;
          }

          @keyframes checkItemAppear {
            from {
              opacity: 0;
              transform: translateY(24px);
            }

            to {
              opacity: 1;
              transform: translateY(0);
            }
          }

          @keyframes checkBoxValidate {
            0% {
              color: transparent;
              background: white;
              transform: scale(0.92);
            }

            45% {
              color: white;
              background: var(--brown-soft);
              transform: scale(1.08);
            }

            100% {
              color: white;
              background: var(--brown-soft);
              transform: scale(1);
            }
          }

          @keyframes textGrow {
            0% {
              transform: scale(1);
            }

            45% {
              transform: scale(1.018);
              color: var(--brown-deep);
            }

            100% {
              transform: scale(1);
            }
          }

          @keyframes buttonPop {
            0% {
              opacity: 0;
              transform: scale(0.92);
            }

            55% {
              opacity: 1;
              transform: scale(1.045);
            }

            100% {
              opacity: 1;
              transform: scale(1);
            }
          }

          @media (max-width: 640px) {
            .parcours-check-card {
              border-radius: 1.5rem;
              padding: 1.35rem;
            }

            .parcours-check-list {
              gap: 1.25rem;
            }

            .parcours-check-item {
              gap: 0.85rem;
            }

            .parcours-check-box {
              width: 1.75rem;
              height: 1.75rem;
              flex-basis: 1.75rem;
              border-radius: 0.65rem;
            }

            .parcours-check-buttons {
              display: grid;
            }
          }

          @media (prefers-reduced-motion: reduce) {
            .parcours-check-section,
            .parcours-check-item,
            .parcours-check-box,
            .parcours-check-text,
            .parcours-check-btn {
              animation: none !important;
              opacity: 1 !important;
              transform: none !important;
            }

            .parcours-check-box {
              color: white;
              background: var(--brown-soft);
            }
          }
        </style>

        <script is:inline>
          const setupParcoursCheckAnimation = () => {
            const section = document.querySelector(".parcours-check-section");

            if (!section) return;

            const observer = new IntersectionObserver(
              ([entry]) => {
                if (entry.isIntersecting) {
                  section.classList.add("is-visible");
                  observer.disconnect();
                }
              },
              {
                threshold: 0.3,
              }
            );

            observer.observe(section);
          };

          if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", setupParcoursCheckAnimation);
          } else {
            setupParcoursCheckAnimation();
          }
        </script>
      </section>
    </section>
  </main>

  <Footer />
  <ScrollReveal />
</BaseLayout>