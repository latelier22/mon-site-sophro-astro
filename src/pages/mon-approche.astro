---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import VerticalImageCard from "../components/VerticalImageCard.astro";
---

<BaseLayout
  title="Mon approche de la sophrologie à Loudéac – Alexandra Coirier"
  description="Une approche douce, concrète et personnalisée de la sophrologie à Loudéac pour apaiser l’anxiété, le stress, les émotions et retrouver autonomie, calme et sécurité intérieure."
>
  <Header />

  <main>
    <section class="mx-auto max-w-7xl px-0 sm:px-6 py-8 md:py-16">
      <!-- INTRO -->
      <section class="grid lg:grid-cols-[1.15fr_0.85fr] gap-6 md:gap-8 items-stretch">
        <div class="soft-card rounded-[1.5rem] md:rounded-[2.5rem] p-5 md:p-10 slide-right flex flex-col justify-center">
          <p class="text-sm uppercase tracking-[0.25em] text-[var(--brown-soft)]">
            Mon approche
          </p>

          <h1 class="mt-4 text-4xl md:text-5xl font-semibold text-[var(--brown-deep)]">
            Une sophrologie douce, concrète et personnalisée
          </h1>

          <p class="mt-5 text-lg leading-relaxed text-[var(--text)]">
            Mon approche est globale :
            <strong class="font-semibold text-[var(--brown-deep)]">corps, esprit et émotions</strong>.
            Je vous aide à
            <strong class="font-semibold text-[var(--brown-deep)]">apaiser les tensions</strong>,
            clarifier ce qui se joue en vous et réveiller les
            <strong class="font-semibold text-[var(--brown-deep)]">ressources déjà présentes</strong>.
          </p>
        </div>

        <VerticalImageCard
          src="/images/sophro/lac-mousses.webp"
          alt="Sophrologie douce et accompagnement personnalisé"
          ratio="4 / 5"
          objectPosition="center 45%"
          animation="slide-left"
          className="h-full"
          mobileStart="0%"
          mobileMiddle="50%"
          mobileEnd="100%"
        />
      </section>

      <section class="mt-8 section-bg-new rounded-none sm:rounded-[2.5rem] p-4 sm:p-6 md:p-10">
        <!-- ECOUTER APAISER ANCRER -->
        <section class="grid lg:grid-cols-[0.85fr_1.15fr] gap-6 md:gap-8 items-stretch">
          <VerticalImageCard
            src="/images/sophro/mousses-arbres.webp"
            alt="Nature apaisante et ancrage en sophrologie"
            ratio="4 / 5"
            objectPosition="center"
            animation="slide-right"
            className="h-full"
            mobileStart="0%"
            mobileMiddle="50%"
            mobileEnd="100%"
          />

          <div class="grid md:grid-cols-3 gap-6">
            <div class="soft-card rounded-[1.5rem] md:rounded-[2rem] p-5 md:p-8 zoom-in">
              <h2 class="text-2xl font-semibold text-[var(--brown-deep)]">
                Écouter
              </h2>
              <p class="mt-4 leading-relaxed text-[var(--text)]">
                Un temps d’échange permet de comprendre votre situation,
                vos ressentis, vos besoins et la direction que vous souhaitez prendre.
              </p>
            </div>

            <div class="soft-card rounded-[1.5rem] md:rounded-[2rem] p-5 md:p-8 zoom-in">
              <h2 class="text-2xl font-semibold text-[var(--brown-deep)]">
                Apaiser
              </h2>
              <p class="mt-4 leading-relaxed text-[var(--text)]">
                Les exercices de
                <strong class="font-semibold text-[var(--brown-deep)]">respiration</strong>,
                de détente corporelle et de visualisation permettent de
                <strong class="font-semibold text-[var(--brown-deep)]">relâcher progressivement les tensions</strong>.
              </p>
            </div>

            <div class="soft-card rounded-[1.5rem] md:rounded-[2rem] p-5 md:p-8 zoom-in">
              <h2 class="text-2xl font-semibold text-[var(--brown-deep)]">
                Ancrer
              </h2>
              <p class="mt-4 leading-relaxed text-[var(--text)]">
                Vous repartez avec des
                <strong class="font-semibold text-[var(--brown-deep)]">outils simples</strong>
                à réutiliser entre les séances pour avancer à votre rythme.
              </p>
            </div>
          </div>
        </section>

        <!-- PEDAGOGIE -->
        <section class="mt-8 grid lg:grid-cols-[1.15fr_0.85fr] gap-6 md:gap-8 items-stretch">
          <div class="soft-card rounded-[1.5rem] md:rounded-[2rem] p-5 md:p-8 slide-right flex flex-col justify-center">
            <h2 class="text-2xl font-semibold text-[var(--brown-deep)]">
              Une pédagogie de la vie
            </h2>

            <div class="mt-5 space-y-4 leading-relaxed text-[var(--text)]">
              <p>
                Pour moi, la
                <strong class="font-semibold text-[var(--brown-deep)]">sophrologie</strong>
                est plus qu’un outil de relaxation. C’est une pédagogie de la vie
                qui aide à mieux se connaître, se respecter et développer une
                relation plus douce avec soi-même.
              </p>

              <p>
                Chaque séance s’adapte à votre état du moment. Parfois la pratique prend
                plus de place, parfois l’échange est essentiel. Le cadre reste toujours
                <strong class="font-semibold text-[var(--brown-deep)]">sécurisant</strong>,
                progressif et respectueux de votre rythme.
              </p>

              <p>
                Même dans les séances relaxantes, vous restez consciente et actrice
                de votre expérience. L’objectif est de retrouver de
                <strong class="font-semibold text-[var(--brown-deep)]">l’autonomie</strong>,
                du calme et une
                <strong class="font-semibold text-[var(--brown-deep)]">sécurité intérieure durable</strong>.
              </p>
            </div>
          </div>

          <VerticalImageCard
            src="/images/sophro/eaux-rochers-apaisants.webp"
            alt="Apaisement, calme et sécurité intérieure"
            ratio="4 / 5"
            objectPosition="center"
            animation="slide-left"
            className="h-full"
            mobileStart="0%"
            mobileMiddle="50%"
            mobileEnd="100%"
          />
        </section>

        <!-- ACCOMPAGNEMENT -->
        <section class="mt-8 grid lg:grid-cols-[0.85fr_1.15fr] gap-6 md:gap-8 items-stretch">
          <VerticalImageCard
            src="/images/sophro/sculpture-2.webp"
            alt="Accompagnement en sophrologie pour retrouver équilibre et ancrage"
            ratio="4 / 5"
            objectPosition="center"
            animation="slide-right"
            className="h-full"
            mobileStart="0%"
            mobileMiddle="50%"
            mobileEnd="100%"
          />

          <div class="soft-card rounded-[1.5rem] md:rounded-[2rem] p-5 md:p-8 slide-left flex flex-col justify-center">
            <h2 class="text-2xl font-semibold text-[var(--brown-deep)]">
              Comment puis-je vous accompagner ?
            </h2>

            <ul class="mt-5 space-y-3 leading-relaxed text-[var(--text)]">
              <li>
                • <strong class="font-semibold text-[var(--brown-deep)]">Apaiser l’anxiété chronique</strong>,
                le stress et les angoisses
              </li>
              <li>
                • Retrouver un
                <strong class="font-semibold text-[var(--brown-deep)]">sommeil plus serein et réparateur</strong>
              </li>
              <li>
                • Renforcer
                <strong class="font-semibold text-[var(--brown-deep)]">l’estime et la confiance en soi</strong>
              </li>
              <li>
                • Traverser une période de transition ou de
                <strong class="font-semibold text-[var(--brown-deep)]">surcharge mentale</strong>
              </li>
              <li>
                • Revenir au
                <strong class="font-semibold text-[var(--brown-deep)]">corps</strong>,
                au <strong class="font-semibold text-[var(--brown-deep)]">souffle</strong>
                et à vos ressentis
              </li>
            </ul>

            <div class="mt-8 flex flex-wrap gap-4">
              <a
                href="/a-quoi-s-attendre"
                class="soft-btn border border-[var(--brown-soft)]/20 bg-white/70 px-7 py-3.5 text-[var(--brown-deep)] hover:bg-white"
              >
                À quoi s’attendre ?
              </a>

              <a
                href="/contact"
                class="soft-btn bg-[var(--brown-soft)] text-white px-7 py-3.5 font-medium inline-block hover:bg-[var(--brown-deep)]"
              >
                Prendre rendez-vous
              </a>
            </div>
          </div>
        </section>
      </section>
    </section>
  </main>

  <Footer />
  <ScrollReveal />
</BaseLayout>