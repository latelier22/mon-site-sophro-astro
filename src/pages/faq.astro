---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import AnimatedFAQ from "../components/AnimatedFAQ.astro";
import WideImageBanner from "../components/WideImageBanner.astro";
---

<BaseLayout title="FAQ – Alexandra Coirier" description="Questions fréquentes sur la sophrologie, les séances et les modalités.">
  <Header />

  <main class="mx-auto max-w-7xl px-4 sm:px-6 py-10 md:py-16">

       <section class="mb-8">
      <WideImageBanner
        src="/images/sophro/eaux-rochers-apaisants.webp"
        alt=""
        ratio="16 / 7"
        objectPosition="center 50%"
        animation="fade-in"
      />
    </section>
<AnimatedFAQ />

  </main>

  <Footer />
  <ScrollReveal />
</BaseLayout>