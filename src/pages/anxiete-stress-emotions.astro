---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import VerticalImageCard from "../components/VerticalImageCard.astro";
---

<BaseLayout
  title="Anxiété, stress et émotions – Sophrologue à Loudéac"
  description="Anxiété, stress, angoisse, charge mentale, émotions envahissantes… Découvrez comment la sophrologie à Loudéac peut vous aider à retrouver calme, clarté et sérénité."
>
  <Header />

  <main>
    <section class="mx-auto max-w-7xl px-4 sm:px-6 py-10 md:py-16">
      <!-- INTRO -->
      <section class="grid lg:grid-cols-[1.15fr_0.85fr] gap-8 items-stretch">
        <div class="soft-card rounded-[1.5rem] md:rounded-[2.5rem] p-5 md:p-10 slide-right flex flex-col justify-center">
          <p class="text-sm uppercase tracking-[0.25em] text-[var(--brown-soft)]">
            Anxiété · Stress · Émotions
          </p>

          <h1 class="mt-4 text-4xl md:text-5xl font-semibold text-[var(--brown-deep)]">
            Anxiété, stress, émotions…
            <br />et si ça pouvait vraiment s’apaiser ?
          </h1>

          <p class="mt-6 text-lg leading-relaxed text-[var(--text)]">
            Vous ressentez peut-être une
            <strong class="font-semibold text-[var(--brown-deep)]">tension constante</strong>,
            un mental qui ne s’arrête jamais, ou des
            <strong class="font-semibold text-[var(--brown-deep)]">émotions envahissantes</strong>
            qui prennent trop de place.
          </p>

          <p class="mt-4 text-lg leading-relaxed text-[var(--text)]">
            Et si vous pouviez enfin souffler, comprendre ce qui se passe en vous,
            et retrouver un
            <strong class="font-semibold text-[var(--brown-deep)]">équilibre plus stable et apaisé</strong> ?
          </p>
        </div>

        <VerticalImageCard
          src="/images/sophro/moi-respiration-consciente.webp"
          alt="Respiration consciente pour apaiser l’anxiété et le stress"
          ratio="4 / 5"
          objectPosition="center 35%"
          animation="slide-left"
          className="h-full"
        />
      </section>

      <section class="mt-8 section-bg-new rounded-[2.5rem] p-8 md:p-10">
        <!-- BLOC 1 -->
        <section class="grid lg:grid-cols-[0.85fr_1.15fr] gap-8 items-stretch">
          <VerticalImageCard
            src="/images/sophro/banc-sous-le-cerisier.webp"
            alt="Pause calme pour retrouver sérénité et apaisement"
            ratio="4 / 5"
            objectPosition="center 40%"
            animation="slide-right"
            className="h-full"
          />

          <div class="soft-card rounded-[2rem] p-8 fade-in flex flex-col justify-center">
            <h2 class="text-2xl font-semibold text-[var(--brown-deep)]">
              Vous vous reconnaissez peut-être…
            </h2>

            <ul class="mt-6 space-y-4 text-[var(--text)]">
              <li class="bg-white/70 rounded-[1.25rem] p-4 zoom-in">
                Vous anticipez tout, vous ressassez, vous avez du mal à
                <strong class="font-semibold text-[var(--brown-deep)]">couper le mental</strong>.
              </li>

              <li class="bg-white/70 rounded-[1.25rem] p-4 zoom-in">
                Vous ressentez une
                <strong class="font-semibold text-[var(--brown-deep)]">fatigue permanente</strong>,
                comme si votre cerveau ne s’arrêtait jamais.
              </li>

              <li class="bg-white/70 rounded-[1.25rem] p-4 zoom-in">
                Vous avez des
                <strong class="font-semibold text-[var(--brown-deep)]">tensions dans le corps</strong>,
                des douleurs, un
                <strong class="font-semibold text-[var(--brown-deep)]">sommeil perturbé</strong>.
              </li>

              <li class="bg-white/70 rounded-[1.25rem] p-4 zoom-in">
                Vous vous sentez submergé(e) par vos
                <strong class="font-semibold text-[var(--brown-deep)]">émotions</strong>
                ou en décalage avec les autres.
              </li>

              <li class="bg-white/70 rounded-[1.25rem] p-4 zoom-in">
                Vous avez parfois l’impression de ne plus vous reconnaître.
              </li>
            </ul>
          </div>
        </section>

        <!-- BLOC 2 -->
        <section class="mt-8 grid lg:grid-cols-[1.15fr_0.85fr] gap-8 items-stretch">
          <div class="soft-card rounded-[2rem] p-8 slide-right flex flex-col justify-center">
            <h2 class="text-2xl font-semibold text-[var(--brown-deep)]">
              Ce n’est pas “vous le problème”
            </h2>

            <div class="mt-5 space-y-4 text-[var(--text)] leading-relaxed">
              <p>
                Ce que vous vivez n’est pas une faiblesse. C’est souvent le résultat
                d’un <strong class="font-semibold text-[var(--brown-deep)]">système nerveux en surcharge</strong>,
                qui est resté trop longtemps en état d’alerte.
              </p>

              <p>
                Votre corps et votre mental essaient de vous protéger… mais à force,
                cela devient <strong class="font-semibold text-[var(--brown-deep)]">épuisant</strong>.
              </p>

              <p class="font-medium text-[var(--brown-deep)]">
                La bonne nouvelle, c’est que cela peut évoluer.
              </p>
            </div>
          </div>

          <VerticalImageCard
            src="/images/sophro/calme-introspection.webp"
            alt="Calme et introspection pour apaiser le stress"
            ratio="4 / 5"
            objectPosition="center"
            animation="slide-left"
            className="h-full"
          />
        </section>

        <!-- BLOC 3 -->
        <section class="mt-8 grid lg:grid-cols-[0.85fr_1.15fr] gap-8 items-stretch">
          <VerticalImageCard
            src="/images/sophro/respiration-et-centration.webp"
            alt="Respiration et centration en sophrologie"
            ratio="4 / 5"
            objectPosition="center 40%"
            animation="slide-right"
            className="h-full"
          />

          <div class="grid gap-6">
            <div class="soft-card rounded-[2rem] p-8 slide-left">
              <h2 class="text-2xl font-semibold text-[var(--brown-deep)]">
                Ce que la sophrologie permet
              </h2>

              <ul class="mt-5 space-y-3 text-[var(--text)]">
                <li>• <strong class="font-semibold text-[var(--brown-deep)]">Apaiser le système nerveux</strong></li>
                <li>• Relâcher les tensions physiques</li>
                <li>• Sortir de l’hyper-contrôle mental</li>
                <li>• Retrouver un état de calme</li>
                <li>• Mieux comprendre ses émotions</li>
                <li>• Reprendre confiance en soi</li>
              </ul>
            </div>

            <div class="soft-card rounded-[2rem] p-8 slide-left">
              <h2 class="text-2xl font-semibold text-[var(--brown-deep)]">
                Comment ça fonctionne
              </h2>

              <ul class="mt-5 space-y-3 text-[var(--text)]">
                <li>• <strong class="font-semibold text-[var(--brown-deep)]">Respiration guidée</strong></li>
                <li>• Mouvements doux</li>
                <li>• Visualisations</li>
                <li>• Travail sur les ressentis</li>
                <li>• Outils concrets à utiliser chez vous</li>
              </ul>

              <p class="mt-6 text-sm text-[var(--brown-soft)]">
                Vous restez toujours actif(ve) dans votre expérience.
              </p>
            </div>
          </div>
        </section>

        <!-- BLOC 4 -->
        <section class="mt-8 grid lg:grid-cols-[1.15fr_0.85fr] gap-8 items-stretch">
          <div class="soft-card rounded-[2rem] p-8 fade-in flex flex-col justify-center">
            <h2 class="text-2xl font-semibold text-[var(--brown-deep)]">
              Et si ça changeait vraiment ?
            </h2>

            <div class="mt-5 space-y-4 text-[var(--text)] leading-relaxed">
              <p>Imaginez :</p>

              <ul class="space-y-2">
                <li>• vous réveiller sans boule au ventre</li>
                <li>• vous sentir plus calme dans votre quotidien</li>
                <li>• retrouver de l’énergie</li>
                <li>• être plus à l’aise avec vous-même et avec les autres</li>
              </ul>

              <p class="font-medium text-[var(--brown-deep)]">
                Pas en devenant quelqu’un d’autre… mais en revenant à vous.
              </p>
            </div>
          </div>

          <VerticalImageCard
            src="/images/sophro/instant-present-resilience.webp"
            alt="Retrouver calme, énergie et sérénité"
            ratio="4 / 5"
            objectPosition="center 45%"
            animation="slide-left"
            className="h-full"
          />
        </section>

        <!-- FINAL -->
        <section class="mt-8 grid lg:grid-cols-[0.85fr_1.15fr] gap-8 items-stretch">
          <VerticalImageCard
            src="/images/sophro/lac-ouvrir-le-champs-des-possibles.webp"
            alt="Ouvrir le champ des possibles grâce à la sophrologie"
            ratio="4 / 5"
            objectPosition="center 45%"
            animation="slide-right"
            className="h-full"
            mobileStart="50%"
            mobileMiddle="75%"
            mobileEnd="100%"
          />

          <div class="soft-card rounded-[2rem] p-8 text-center zoom-in flex flex-col justify-center">
            <h2 class="text-2xl font-semibold text-[var(--brown-deep)]">
              Faire un premier pas
            </h2>

            <p class="mt-5 text-[var(--text)]">
              Un premier échange permet de faire le point sur votre situation
              et de voir si cet
              <strong class="font-semibold text-[var(--brown-deep)]">accompagnement en sophrologie</strong>
              peut vous aider.
            </p>

            <div class="mt-8 flex flex-wrap justify-center gap-4">
              <a
                href="/contact"
                class="soft-btn bg-[var(--brown-soft)] text-white px-7 py-3.5 font-medium hover:bg-[var(--brown-deep)]"
              >
                Prendre rendez-vous
              </a>

              <a
                href="/accompagnement"
                class="soft-btn border border-[var(--brown-soft)]/20 bg-white/70 px-7 py-3.5 text-[var(--brown-deep)] hover:bg-white"
              >
                Voir les accompagnements
              </a>
            </div>
          </div>
        </section>
      </section>
    </section>
  </main>

  <Footer />
  <ScrollReveal />
</BaseLayout>