<script is:inline>
  (() => {
    const CALENDLY_SRC = "https://assets.calendly.com/assets/external/widget.js";

    const loadCalendly = () => {
      return new Promise((resolve, reject) => {
        if (window.Calendly) {
          resolve(window.Calendly);
          return;
        }

        let script = document.querySelector('script[data-calendly-global="true"]');

        if (!script) {
          script = document.createElement("script");
          script.src = CALENDLY_SRC;
          script.async = true;
          script.dataset.calendlyGlobal = "true";
          script.onload = () => resolve(window.Calendly);
          script.onerror = reject;
          document.head.appendChild(script);
        } else {
          script.addEventListener("load", () => resolve(window.Calendly), { once: true });
          script.addEventListener("error", reject, { once: true });
        }
      });
    };

    const openCalendlyPopup = async (url) => {
      try {
        await loadCalendly();

        if (window.Calendly) {
          window.Calendly.initPopupWidget({ url });
          return;
        }

        window.location.href = url;
      } catch (err) {
        console.error("Calendly error:", err);
        window.location.href = url;
      }
    };

    const bindCalendlyButtons = () => {
      document.querySelectorAll("[data-calendly-url]").forEach((el) => {
        if (el.dataset.calendlyBound === "true") return;
        el.dataset.calendlyBound = "true";

        el.addEventListener("click", (e) => {
          e.preventDefault();
          const url = el.getAttribute("data-calendly-url");
          if (!url) return;
          openCalendlyPopup(url);
        });
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", bindCalendlyButtons);
    } else {
      bindCalendlyButtons();
    }
  })();
</script>