  autoplayMs = 4200,
} = Astro.props;

const carouselId = `sophro-strip-${Math.random().toString(36).slice(2, 9)}`;
---

<section
  id={carouselId}
  class="sophro-strip"
  data-autoplay={autoplayMs}
>
  <div class="sophro-strip__viewport">
    <div class="sophro-strip__fade sophro-strip__fade--left"></div>
    <div class="sophro-strip__fade sophro-strip__fade--right"></div>

    <div class="sophro-strip__track" data-track>
      {items.map((item, index) => (
        <article class="sophro-strip__item" data-item={index}>
          <div class="sophro-strip__card">
            <img
              src={item.src}
              alt={item.alt ?? `Image ${index + 1}`}
              class="sophro-strip__img"
              loading={index < 4 ? "eager" : "lazy"}
            />
          </div>
        </article>
      ))}
    </div>
  </div>

  <div class="sophro-strip__controls">
    <button type="button" class="sophro-strip__arrow" data-prev aria-label="Précédent">
      ‹
    </button>

    <div class="sophro-strip__dots" data-dots></div>

    <button type="button" class="sophro-strip__arrow" data-next aria-label="Suivant">
      ›
    </button>
  </div>
</section>

<script is:inline define:vars={{ carouselId }}>
  (() => {
    const root = document.getElementById(carouselId);
    if (!root) return;

    const track = root.querySelector("[data-track]");
    const prevBtn = root.querySelector("[data-prev]");
    const nextBtn = root.querySelector("[data-next]");
    const dotsWrap = root.querySelector("[data-dots]");
    const autoplayMs = Number(root.dataset.autoplay || 4200);

    let items = Array.from(root.querySelectorAll("[data-item]"));
    let index = 0;
    let timer = null;

    const getStep = () => {
      const first = items[0];
      if (!first) return 0;
      const styles = window.getComputedStyle(track);
      const gap = parseFloat(styles.columnGap || styles.gap || "0");
      return first.getBoundingClientRect().width + gap;
    };

    const getVisibleCount = () => {
      const viewportWidth = root.querySelector(".sophro-strip__viewport")?.getBoundingClientRect().width || 0;
      const step = getStep();
      if (!step) return 1;
      return Math.max(1, Math.floor(viewportWidth / step));
    };

    const getMaxIndex = () => {
      const visible = getVisibleCount();
      return Math.max(0, items.length - visible);
    };

    const renderDots = () => {
      if (!dotsWrap) return;
      dotsWrap.innerHTML = "";
      const pages = getMaxIndex() + 1;

      for (let i = 0; i < pages; i++) {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "sophro-strip__dot";
        if (i === index) btn.classList.add("is-active");
        btn.setAttribute("aria-label", `Aller à la position ${i + 1}`);
        btn.addEventListener("click", () => {
          index = i;
          update();
          start();
        });
        dotsWrap.appendChild(btn);
      }
    };

    const updateDots = () => {
      const dots = Array.from(root.querySelectorAll(".sophro-strip__dot"));
      dots.forEach((dot, i) => {
        dot.classList.toggle("is-active", i === index);
      });
    };

    const update = () => {
      const maxIndex = getMaxIndex();
      if (index > maxIndex) index = maxIndex;
      if (index < 0) index = 0;

      const step = getStep();
      const x = -(index * step);
      track.style.transform = `translate3d(${x}px, 0, 0)`;

      prevBtn?.toggleAttribute("disabled", index <= 0);
      nextBtn?.toggleAttribute("disabled", index >= maxIndex);

      updateDots();
    };

    const next = () => {
      const maxIndex = getMaxIndex();
      index = index >= maxIndex ? 0 : index + 1;
      update();
    };

    const prev = () => {
      const maxIndex = getMaxIndex();
      index = index <= 0 ? maxIndex : index - 1;
      update();
    };

    const start = () => {
      stop();
      if (items.length <= 1) return;
      timer = window.setInterval(next, autoplayMs);
    };

    const stop = () => {
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
    };

    root.querySelectorAll(".sophro-strip__img").forEach((img) => {
      img.addEventListener("error", () => {
        const article = img.closest("[data-item]");
        article?.remove();
        items = Array.from(root.querySelectorAll("[data-item]"));
        renderDots();
        update();
      }, { once: true });
    });

    prevBtn?.addEventListener("click", () => {
      prev();
      start();
    });

    nextBtn?.addEventListener("click", () => {
      next();
      start();
    });

    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);
    root.addEventListener("focusin", stop);
    root.addEventListener("focusout", start);

    window.addEventListener("resize", () => {
      renderDots();
      update();
    });

    renderDots();
    update();
    start();
  })();
</script>