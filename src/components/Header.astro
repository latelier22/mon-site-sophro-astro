---
import CalendlyButton from "./CalendlyButton.astro";

const links = [
  { href: "/", label: "Accueil" },
  { href: "/a-quoi-s-attendre", label: "À quoi s’attendre ?" },
  { href: "/accompagnement", label: "Accompagnements" },
  { href: "/tarifs", label: "Tarifs et modalités" },
  { href: "/contact", label: "Contact" },
];

const moreLinks = [
  { href: "/anxiete-stress-emotions", label: "Anxiété, stress et émotions" },
  { href: "/mon-approche", label: "Mon approche" },
  { href: "/sophrologie-pour-qui", label: "La sophrologie est-elle faite pour moi ?" },
  { href: "/temoignages", label: "Témoignages" },
  { href: "/sophrologue-loudeac", label: "Sophrologue à Loudéac" },
  { href: "/qui-suis-je", label: "Qui suis-je ?" },
  { href: "/faq", label: "FAQ" },
];

const calendlyUrl = "https://calendly.com/alexandracoirier-sophrologue/?hide_gdpr_banner=1&primary_color=9a6750&text_color=5e4a42&background_color=f8f2ef";

const ctaDesktop =
  "header-cta hidden sm:inline-flex h-12 min-w-[170px] items-center justify-center rounded-full bg-[var(--brown-soft)] px-6 text-sm font-semibold text-white hover:bg-[var(--brown-deep)]";

const ctaMobile =
  "header-cta sm:hidden inline-flex h-10 flex-1 items-center justify-center rounded-full bg-[var(--brown-soft)] px-3 text-[0.78rem] font-semibold text-white hover:bg-[var(--brown-deep)]";
---

<header id="site-top" class="sticky top-0 z-50">
  <div class="mx-auto max-w-7xl px-0 sm:px-6 pt-0 sm:pt-4">
    <div class="header-panel relative overflow-visible rounded-[2.5rem] shadow-xl">
      <div class="header-bg-mask absolute inset-0 overflow-hidden rounded-[2.5rem]">
        <div class="header-bg"></div>
      </div>

      <div class="header-dark relative z-10 px-4 sm:px-6 py-4">
        <div class="flex items-center justify-between gap-4">
          <a href="/" class="flex min-w-0 items-center gap-3">
            <img
              src="/images/sophro/moi-pont-plage.webp"
              alt="Alexandra Coirier"
              width="56"
              height="56"
              class="header-portrait h-14 w-14 rounded-full object-cover ring-2 ring-white/70 shadow-lg"
            />

            <span class="min-w-0">
              <span class="header-name block truncate text-lg sm:text-2xl font-semibold tracking-wide text-white">
                Alexandra Coirier
              </span>
              <span class="header-job block text-xs sm:text-sm uppercase tracking-[0.28em] text-white/75">
                Sophrologue
              </span>
            </span>
          </a>

          <nav class="hidden lg:flex items-center gap-5 text-sm">
            {links.slice(0, 4).map((link) => (
              <a href={link.href} class="header-dark-link">{link.label}</a>
            ))}

            <div class="relative group">
              <button type="button" class="header-dark-link flex items-center gap-1">
                En savoir plus <span>▾</span>
              </button>

              <div class="absolute right-0 top-full pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition z-[9999]">
               <div class="header-more-panel w-[340px] rounded-[1.5rem] p-3 shadow-2xl border">
  {moreLinks.map((link) => (
    <a
      href={link.href}
      class="header-more-link block rounded-[1rem] px-4 py-3"
    >
      {link.label}
    </a>
  ))}
</div>
              </div>
            </div>

            {links.slice(4).map((link) => (
              <a href={link.href} class="header-dark-link">{link.label}</a>
            ))}
          </nav>

          <button
            type="button"
            class="lg:hidden flex h-11 w-11 items-center justify-center rounded-full bg-white/85 border border-white/40 text-[var(--brown-deep)] shadow-sm"
            aria-label="Ouvrir le menu"
            aria-controls="mobile-menu"
            aria-expanded="false"
            data-menu-toggle
          >
            <span class="text-3xl font-black leading-none">☰</span>
          </button>
        </div>

        <div id="mobile-menu" class="mobile-menu lg:hidden" hidden>
          <nav class="mt-5 flex flex-col gap-2">
            {links.map((link) => (
              <a href={link.href} class="mobile-dark-link">{link.label}</a>
            ))}

           <div class="mobile-more-panel mt-3 rounded-[1.5rem] p-3">
  <p class="mobile-more-title px-3 pb-2 text-xs uppercase tracking-[0.2em]">
    En savoir plus
  </p>

  {moreLinks.map((link) => (
    <a href={link.href} class="mobile-more-link">{link.label}</a>
  ))}
</div>
          </nav>
        </div>
      </div>

      <div class="header-light relative z-0">
        <a href="#site-footer" class="header-scroll-link" aria-label="Aller en bas de page">
          ↓
        </a>

        <div class="header-light-buttons">
          <CalendlyButton
            label="Prendre rendez-vous"
            className={ctaDesktop}
            url={calendlyUrl}
          />

          <CalendlyButton
            label="RDV"
            className={ctaMobile}
            url={calendlyUrl}
          />

          <a href="/contact" class={`${ctaDesktop} !bg-[var(--peach)] !text-[var(--brown-deep)] border border-[var(--brown-soft)]/25 hover:!bg-white`}>
            Me contacter
          </a>

          <a href="/contact" class={`${ctaMobile} !bg-white/90 !text-[var(--brown-deep)] border border-[var(--brown-soft)]/25 hover:!bg-white`}>
            Me contacter
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  const setupHeaderMenu = () => {
    const button = document.querySelector("[data-menu-toggle]");
    const menu = document.getElementById("mobile-menu");

    if (!button || !menu) return;

    button.addEventListener("click", () => {
      const isOpen = button.getAttribute("aria-expanded") === "true";
      button.setAttribute("aria-expanded", String(!isOpen));
      button.classList.toggle("is-open", !isOpen);

      if (isOpen) {
        menu.classList.remove("open");
        setTimeout(() => {
          menu.hidden = true;
        }, 260);
      } else {
        menu.hidden = false;
        requestAnimationFrame(() => {
          menu.classList.add("open");
        });
      }
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupHeaderMenu);
  } else {
    setupHeaderMenu();
  }
</script>

<style>
.header-panel {
  min-height: 200px;
}

.header-bg {
  position: absolute;
  inset: 0;
  background-image: url("/images/header-bg-new.png");
  background-size: cover;
  background-position: center 90%;
  transform: scale(1.03);
}

.header-dark {
  background: var(--header-dark-bg);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}

.header-light {
  height: 200px;
  background: var(--header-light-bg);
}

.header-dark-link {
  color: var(--header-link-text);
  transition: color 220ms ease, transform 220ms ease;
  white-space: nowrap;
}

.header-dark-link:hover {
  color: var(--header-link-hover);
  transform: translateY(-1px);
}

.mobile-dark-link {
  display: block;
  border-radius: 1rem;
  padding: 0.85rem 1rem;
  color: var(--cream-94);
  background: var(--cream-10);
  border: 1px solid var(--cream-10);
  transition: background 220ms ease, transform 220ms ease;
}

.mobile-dark-link:hover {
  background: var(--cream-18);
  color: var(--cream);
  transform: translateX(3px);
}

.mobile-menu.open {
  max-height: 1500px;
}

.header-scroll-link {
  position: absolute;
  left: 1.5rem;
  bottom: 1.5rem;
  width: 52px;
  height: 52px;
  border-radius: 999px;
  display: grid;
  place-items: center;
  background: var(--brown-soft);
  color: var(--cream);
  font-size: 1.8rem;
  font-weight: 700;
  box-shadow: 0 12px 28px var(--brown-deep-18);
  text-decoration: none;
  transition: transform 220ms ease, background 220ms ease;
}

.header-scroll-link:hover {
  transform: translateY(2px);
  background: var(--brown-deep);
}

.header-light-buttons {
  position: absolute;
  right: 1.5rem;
  bottom: 1.5rem;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 0.75rem;
}

.header-cta {
  box-shadow: 0 10px 24px var(--brown-deep-12);
  transition: transform 220ms ease, background 220ms ease;
}

.header-cta:hover {
  transform: translateY(-1px);
}

.header-portrait {
  border-color: var(--cream-72);
}

.header-more-panel {
  background: var(--more-panel-bg);
  border-color: var(--more-panel-border);
}

.header-more-link {
  color: var(--more-link-text);
  transition: background 220ms ease, transform 220ms ease, color 220ms ease;
}

.header-more-link:hover {
  color: var(--more-link-hover-text);
  background: var(--more-link-hover-bg);
  transform: translateX(3px);
}

@media (max-width: 1023px) {
  .header-panel {
    min-height: auto;
  }

  .header-dark {
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
  }

  .header-light {
    height: 100px;
  }

  .header-light-buttons {
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    justify-content: center;
  }

  .header-scroll-link {
    display: none;
  }
}

@media (max-width: 640px) {
  .header-panel,
  .header-bg-mask {
    border-radius: 1.5rem;
  }

  .header-bg {
    background-position: center 86%;
  }

  .header-dark {
    padding: 0.7rem 0.85rem;
    background: var(--header-dark-bg-mobile);
  }

  .header-portrait {
    width: 44px;
    height: 44px;
  }

  .header-name {
    font-size: 1rem;
  }

  .header-job {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
  }

  .header-light {
    height: 68px;
    background: var(--header-light-bg-mobile);
  }

  .header-light-buttons {
    left: 0.75rem;
    right: 0.75rem;
    bottom: 0.7rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }
}

.mobile-more-panel {
  background: var(--more-panel-bg);
  border: 1px solid var(--more-panel-border);
}

.mobile-more-title {
  color: var(--brown-deep);
}

.mobile-more-link {
  display: block;
  border-radius: 1rem;
  padding: 0.85rem 1rem;
  color: var(--brown-deep);
  background: var(--cream-30);
  border: 1px solid var(--cream-34);
  transition: background 220ms ease, transform 220ms ease, color 220ms ease;
}

.mobile-more-link:hover {
  color: var(--brown-deep);
  background: var(--cream-72);
  transform: translateX(3px);
}
</style>