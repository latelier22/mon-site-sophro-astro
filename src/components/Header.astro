---
import CalendlyButton from "./CalendlyButton.astro";

const links = [
  { href: "/", label: "Accueil" },
  { href: "/a-quoi-s-attendre", label: "À quoi s’attendre" },
  { href: "/accompagnement", label: "Accompagnements" },
  { href: "/tarifs", label: "Tarifs" },
  { href: "/contact", label: "Contact" },
];

const moreLinks = [
  { href: "/anxiete-stress-emotions", label: "Anxiété, stress et émotions" },
  { href: "/mon-approche", label: "Mon approche" },
  { href: "/sophrologie-pour-qui", label: "La sophrologie est-elle faite pour moi ?" },
  { href: "/temoignages", label: "Témoignages" },
  { href: "/sophrologue-loudeac", label: "Sophrologue à Loudéac" },
  { href: "/qui-suis-je", label: "Qui suis-je ?" },
  { href: "/faq", label: "FAQ" },
];
---

<header class="sticky top-0 z-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 pt-4">
    <div class="soft-card rounded-[2rem] px-4 sm:px-6 py-4">
      <div class="flex items-center justify-between gap-4">
        <a href="/" class="flex min-w-0 items-center gap-3">
          <span class="header-logo-wrap">
            <img
              src="/images/logo-header.png"
              alt="Logo Alexandra Coirier"
              class="header-logo"
            />
          </span>

          <span class="min-w-0">
            <span class="block truncate text-lg sm:text-2xl font-semibold tracking-wide text-[var(--brown-deep)]">
              Alexandra Coirier
            </span>
            <span class="block text-xs sm:text-sm uppercase tracking-[0.28em] text-[var(--brown-soft)]">
              Sophrologue
            </span>
          </span>
        </a>

       <nav class="hidden md:flex items-center gap-6 text-sm">
  {links.slice(0, 4).map((link) => (
    <a href={link.href} class="nav-link">
      {link.label}
    </a>
  ))}

  <div class="relative group">
    <button type="button" class="nav-link flex items-center gap-1">
      En savoir plus
      <span>▾</span>
    </button>

    <div class="absolute left-0 top-full pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition">
      <div class="soft-card min-w-[260px] rounded-[1.5rem] p-3">
        {moreLinks.map((link) => (
          <a
            href={link.href}
            class="block rounded-[1rem] px-4 py-3 text-[var(--text)] hover:bg-white/70 hover:text-[var(--brown-deep)]"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>

  {links.slice(4).map((link) => (
    <a href={link.href} class="nav-link">
      {link.label}
    </a>
  ))}
</nav>

        <div class="hidden md:flex items-center gap-3">
          <CalendlyButton
            label="Prendre rendez-vous"
            className="px-5 py-2.5 text-sm whitespace-nowrap"
          />
        </div>

        <button
  type="button"
  class="md:hidden flex h-11 w-11 items-center justify-center rounded-full bg-white/70 border border-[var(--brown-soft)]/20 text-[var(--brown-deep)] shadow-sm"
  aria-label="Ouvrir le menu"
  aria-controls="mobile-menu"
  aria-expanded="false"
  data-menu-toggle
>
  <span class="text-3xl font-black leading-none">☰</span>
</button>
      </div>

     <div id="mobile-menu" class="mobile-menu md:hidden" hidden>
  <nav class="mt-5 flex flex-col gap-2">
    {links.map((link) => (
      <a href={link.href} class="mobile-nav-link">
        {link.label}
      </a>
    ))}

    <div class="mt-3 rounded-[1.5rem] bg-white/50 p-3">
      <p class="px-3 pb-2 text-xs uppercase tracking-[0.2em] text-[var(--brown-soft)]">
        En savoir plus
      </p>

      {moreLinks.map((link) => (
        <a href={link.href} class="mobile-nav-link">
          {link.label}
        </a>
      ))}
    </div>
  </nav>

  <CalendlyButton
    label="Prendre rendez-vous"
    className="mt-5 inline-flex w-full items-center justify-center px-5 py-3 text-sm"
  />
</div>
    </div>
  </div>
</header>

<script is:inline>
  const setupHeaderMenu = () => {
    const button = document.querySelector("[data-menu-toggle]");
    const menu = document.getElementById("mobile-menu");

    if (!button || !menu) return;

    button.addEventListener("click", () => {
      const isOpen = button.getAttribute("aria-expanded") === "true";
      button.setAttribute("aria-expanded", String(!isOpen));
      button.classList.toggle("is-open", !isOpen);

      if (isOpen) {
        menu.classList.remove("open");
        setTimeout(() => {
          menu.hidden = true;
        }, 260);
      } else {
        menu.hidden = false;
        requestAnimationFrame(() => {
          menu.classList.add("open");
        });
      }
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupHeaderMenu);
  } else {
    setupHeaderMenu();
  }
</script>