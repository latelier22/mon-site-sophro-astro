---
const {
  src,
  alt = "",
  href = "",
  objectPosition = "center",
  ratio = "4 / 5",
  animation = "zoom-in",
  className = "",

  // Défilement mobile de l'image
  // 0% = haut, 50% = milieu, 100% = bas
  mobileStart = "0%",
  mobileMiddle = "50%",
  mobileEnd = "100%",
  mobileDuration = "16s",
} = Astro.props;

const Tag = href ? "a" : "article";
---

<Tag
  href={href || undefined}
  class={`vertical-image-card ${animation} ${className}`}
  style={`
    --vcard-mobile-start: ${mobileStart};
    --vcard-mobile-middle: ${mobileMiddle};
    --vcard-mobile-end: ${mobileEnd};
    --vcard-mobile-duration: ${mobileDuration};
  `}
>
  <div class="vertical-image-card__image" style={`aspect-ratio:${ratio};`}>
    <img
      src={src}
      alt={alt}
      loading="lazy"
      style={`object-position:${objectPosition};`}
    />
  </div>
</Tag>

<style>
  .vertical-image-card {
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 2rem;
    background: rgba(255, 255, 255, 0.68);
    color: inherit;
    text-decoration: none;
    box-shadow: 0 18px 44px rgba(94, 74, 66, 0.1);
    backdrop-filter: blur(12px);
  }

  .vertical-image-card__image {
    width: 100%;
    height: 100%;
    min-height: 100%;
    overflow: hidden;
  }

  .vertical-image-card__image img {
    width: 100%;
    height: 100%;
    min-height: 100%;
    display: block;
    object-fit: cover;
    transform: scale(1.04);
    transition: transform 1.3s ease;
  }

  .vertical-image-card:hover img {
    transform: scale(1.08);
  }

  @media (max-width: 900px) {
    .vertical-image-card {
      height: auto;
      border-radius: 1.5rem;
      box-shadow: 0 12px 28px rgba(94, 74, 66, 0.09);
    }

    .vertical-image-card__image {
      aspect-ratio: 16 / 11 !important;
      height: auto;
      min-height: 0;
    }

    .vertical-image-card__image img {
      height: 100%;
      min-height: 0;
      object-fit: cover;
      transform: scale(1.12);
      animation: vertical-card-pan-v2 var(--vcard-mobile-duration) ease-in-out infinite both;
    }
  }

  @media (max-width: 520px) {
    .vertical-image-card {
      border-radius: 1.25rem;
    }

    .vertical-image-card__image {
      aspect-ratio: 16 / 12 !important;
    }

    .vertical-image-card__image img {
      transform: scale(1.16);
    }
  }

  @keyframes vertical-card-pan-v2 {
    0% {
      object-position: center var(--vcard-mobile-start);
    }

    20% {
      object-position: center var(--vcard-mobile-start);
    }

    60% {
      object-position: center var(--vcard-mobile-middle);
    }

    100% {
      object-position: center var(--vcard-mobile-end);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .vertical-image-card__image img {
      animation: none !important;
    }
  }
</style>