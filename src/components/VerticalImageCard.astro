---
const {
  src,
  alt = "",
  href = "",
  objectPosition = "center",
  ratio = "4 / 5",
  animation = "zoom-in",
  className = "",
} = Astro.props;

const Tag = href ? "a" : "article";
---

<Tag href={href || undefined} class={`vertical-image-card ${animation} ${className}`}>
  <div class="vertical-image-card__image" style={`aspect-ratio:${ratio};`}>
    <img
      src={src}
      alt={alt}
      loading="lazy"
      style={`object-position:${objectPosition};`}
    />
  </div>
</Tag>

<style>
  .vertical-image-card {
    display: block;
    overflow: hidden;
    border-radius: 2rem;
    background: rgba(255, 255, 255, 0.68);
    color: inherit;
    text-decoration: none;
    box-shadow: 0 18px 44px rgba(94, 74, 66, 0.1);
    backdrop-filter: blur(12px);
  }

  .vertical-image-card__image {
    overflow: hidden;
  }

  .vertical-image-card__image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transform: scale(1.02);
    transition: transform 1.3s ease;
  }

  .vertical-image-card:hover img {
    transform: scale(1.06);
  }
</style>