---
const {
  src,
  alt = "",
  imageSide = "left", // left ou right
  ratio = "4 / 5",
  objectPosition = "center",
  animation = "fade-in",
  imageAnimation = "slide-right",
  textAnimation = "slide-left",
  className = "",
} = Astro.props;

const isRight = imageSide === "right";
---

<section class={`image-side-block ${animation} ${className}`}>
  <div class={`image-side-block__grid ${isRight ? "image-side-block__grid--right" : ""}`}>
    <div class={`image-side-block__image ${imageAnimation}`}>
      <div class="image-side-block__frame" style={`aspect-ratio:${ratio};`}>
        <img
          src={src}
          alt={alt}
          loading="lazy"
          style={`object-position:${objectPosition};`}
        />
      </div>
    </div>

    <div class={`image-side-block__content ${textAnimation}`}>
      <slot />
    </div>
  </div>
</section>

<style>
  .image-side-block {
    width: 100%;
  }

  .image-side-block__grid {
    display: grid;
    grid-template-columns: minmax(260px, 0.8fr) minmax(0, 1.2fr);
    gap: 2rem;
    align-items: stretch;
  }

  .image-side-block__grid--right .image-side-block__image {
    order: 2;
  }

  .image-side-block__grid--right .image-side-block__content {
    order: 1;
  }

  .image-side-block__image {
    min-width: 0;
  }

  .image-side-block__frame {
    overflow: hidden;
    border-radius: 2.5rem;
    background: rgba(255, 255, 255, 0.58);
    box-shadow: 0 22px 60px rgba(94, 74, 66, 0.12);
    padding: 1rem;
    height: 100%;
    max-height: 620px;
  }

  .image-side-block__frame img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border-radius: 2rem;
    transform: scale(1.02);
    transition: transform 1.4s ease;
  }

  .image-side-block:hover img {
    transform: scale(1.055);
  }

  .image-side-block__content {
    min-width: 0;
  }

  .image-side-block__content > :global(*) {
    height: 100%;
  }

  @media (max-width: 900px) {
    .image-side-block__grid,
    .image-side-block__grid--right {
      grid-template-columns: 1fr;
    }

    .image-side-block__grid--right .image-side-block__image,
    .image-side-block__grid--right .image-side-block__content {
      order: initial;
    }

    .image-side-block__frame {
      max-height: none;
    }

    .image-side-block__frame {
      aspect-ratio: 16 / 10 !important;
    }
  }
</style>